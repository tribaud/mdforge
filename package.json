{
  "name": "mdforge",
  "displayName": "MDForge",
  "description": "Transform VS Code into a Typora-like WYSIWYG Markdown editor with GitHub-style rendering, Mermaid diagrams and rich task lists.",
  "version": "0.0.1",
  "publisher": "tribaud",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tribaud/mdforge.git"
  },
  "homepage": "https://github.com/tribaud/mdforge#readme",
  "bugs": {
    "url": "https://github.com/tribaud/mdforge/issues"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "typora",
    "mermaid",
    "github",
    "task list",
    "checkbox",
    "preview"
  ],
  "galleryBanner": {
    "color": "#0d1117",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "mdforge.editor",
        "displayName": "MDForge",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "mdforge.openEditor",
        "title": "MDForge: Open with MDForge",
        "category": "MDForge"
      },
      {
        "command": "mdforge.openWithTextEditor",
        "title": "MDForge: Reopen with Text Editor",
        "category": "MDForge"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "mdforge.outline",
          "name": "MDForge Outline",
          "when": "mdforge.active"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "when": "resourceLangId == markdown",
          "command": "mdforge.openEditor",
          "group": "navigation@20"
        }
      ],
      "editor/title/context": [
        {
          "when": "resourceLangId == markdown",
          "command": "mdforge.openEditor",
          "group": "1_open"
        }
      ]
    },
    "keybindings": [
      {
        "key": "ctrl+shift+alt+m",
        "mac": "cmd+shift+alt+m",
        "command": "mdforge.openEditor",
        "when": "editorTextFocus && editorLangId == markdown"
      }
    ],
    "configuration": {
      "title": "MDForge",
      "properties": {
        "mdforge.checkbox.enableInProgress": {
          "type": "boolean",
          "default": true,
          "description": "Enable the custom [~] 'in progress' state in the checkbox click cycle (empty -> in progress -> done)."
        },
        "mdforge.fontSize": {
          "type": "number",
          "default": 15,
          "minimum": 8,
          "maximum": 48,
          "description": "Editor font size (px)."
        },
        "mdforge.pageWidth": {
          "type": "string",
          "enum": [
            "comfortable",
            "full"
          ],
          "default": "comfortable",
          "description": "Content width: 'comfortable' centers a readable column (GitHub-like), 'full' spans the viewport."
        }
      }
    }
  },
  "scripts": {
    "compile:ext": "tsc -p ./",
    "build:webview": "node esbuild.mjs",
    "build": "npm run compile:ext && npm run build:webview",
    "watch:ext": "tsc -watch -p ./",
    "watch:webview": "node esbuild.mjs --watch",
    "vscode:prepublish": "npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@milkdown/core": "^7.5.0",
    "@milkdown/ctx": "^7.5.0",
    "@milkdown/plugin-clipboard": "^7.5.0",
    "@milkdown/plugin-diagram": "^7.5.0",
    "@milkdown/plugin-history": "^7.5.0",
    "@milkdown/plugin-listener": "^7.5.0",
    "@milkdown/plugin-math": "^7.5.0",
    "@milkdown/plugin-prism": "^7.21.3",
    "@milkdown/plugin-slash": "^7.21.3",
    "@milkdown/plugin-tooltip": "^7.21.3",
    "@milkdown/preset-commonmark": "^7.5.0",
    "@milkdown/preset-gfm": "^7.5.0",
    "@milkdown/prose": "^7.5.0",
    "@milkdown/transformer": "^7.5.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.25.0",
    "katex": "^0.16.11",
    "mermaid": "^11.4.0",
    "prosemirror-highlight": "^0.15.3",
    "remark-frontmatter": "^5.0.0",
    "shiki": "^1.29.2",
    "typescript": "^5.6.0"
  }
}
